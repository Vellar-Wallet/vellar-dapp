{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs",
      "buildCommand": "cd ../.. && pnpm exec turbo build --filter=@vela/web...",
      "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
      "outputDirectory": ".next"
    }
  }
}
