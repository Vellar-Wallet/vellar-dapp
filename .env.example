# Copy to .env for local development. Never commit real secrets.
# Ports match infra/docker/docker-compose.yml (offset to avoid local collisions)
DATABASE_URL=postgres://vela:vela@localhost:5433/vela
REDIS_URL=redis://localhost:6380
# Integration tests truncate tables — ALWAYS a separate database from dev:
TEST_DATABASE_URL=postgres://vela:vela@localhost:5433/vela_test

# api-gateway
PORT=4000
HOST=0.0.0.0
WALLET_SERVICE_URL=http://localhost:4001
# Allowed browser origin(s) for CORS — comma-separated for apex + www.
CORS_ORIGIN=http://localhost:3000
# Security controls (idea.md §12). Defaults shown; override per environment.
# RATE_LIMIT_MAX=120           # requests per IP per window
# RATE_LIMIT_WINDOW_MS=60000   # rate-limit window
# MAX_BODY_BYTES=1048576       # max request body (1 MiB)
# REQUEST_TIMEOUT_MS=30000     # per-connection timeout

# wallet-service
WALLET_SERVICE_PORT=4001
# Defaults to Stellar testnet when unset:
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# OpenZeppelin Relayer (fee-sponsored submission). Server-side only — never expose to the browser.
# Generate a free testnet key at https://channels.openzeppelin.com/testnet/gen
# RELAYER_BASE_URL=https://channels.openzeppelin.com/testnet
# RELAYER_API_KEY=

# lifecycle-service
LIFECYCLE_SERVICE_PORT=4002
LIFECYCLE_SERVICE_URL=http://localhost:4002
# HORIZON_URL=https://horizon-testnet.stellar.org

# policy-service
POLICY_SERVICE_PORT=4003
POLICY_SERVICE_URL=http://localhost:4003
# SPONSOR_SECRET_KEY=          # funds policy instance deploys (server-side only)

# verification-service
VERIFICATION_SERVICE_PORT=4004
VERIFICATION_SERVICE_URL=http://localhost:4004

# worker-service (verification build worker — runs as its OWN isolated process)
# VERIFY_BUILD_IMAGE=vela-verify:1.94.0   # set → real Docker builds; unset → stub
# VERIFY_POLL_IDLE_MS=5000
# Build sandbox caps (§8.4 — the build runs untrusted code). Defaults shown.
# VERIFY_BUILD_TIMEOUT_S=600    # kill a build after this long
# VERIFY_BUILD_MEMORY=2g        # container memory cap
# VERIFY_BUILD_CPUS=2           # container CPU cap
# VERIFY_BUILD_PIDS_LIMIT=512   # max processes (fork-bomb guard)
# WORKER_METRICS_PORT=4005      # worker exposes /health + /metrics here
