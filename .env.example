# Copy to .env for local development. Never commit real secrets.
# Ports match infra/docker/docker-compose.yml (offset to avoid local collisions)
DATABASE_URL=postgres://vela:vela@localhost:5433/vela
REDIS_URL=redis://localhost:6380
# Integration tests truncate tables — ALWAYS a separate database from dev:
TEST_DATABASE_URL=postgres://vela:vela@localhost:5433/vela_test

# api-gateway
PORT=4000
HOST=0.0.0.0
WALLET_SERVICE_URL=http://localhost:4001

# wallet-service
WALLET_SERVICE_PORT=4001
# Defaults to Stellar testnet when unset:
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# OpenZeppelin Relayer (fee-sponsored submission). Server-side only — never expose to the browser.
# Generate a free testnet key at https://channels.openzeppelin.com/testnet/gen
# RELAYER_BASE_URL=https://channels.openzeppelin.com/testnet
# RELAYER_API_KEY=

# lifecycle-service
LIFECYCLE_SERVICE_PORT=4002
LIFECYCLE_SERVICE_URL=http://localhost:4002
# HORIZON_URL=https://horizon-testnet.stellar.org

# policy-service
POLICY_SERVICE_PORT=4003
POLICY_SERVICE_URL=http://localhost:4003
