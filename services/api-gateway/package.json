{
  "name": "@vela/api-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "Unified API entrypoint: auth/session middleware, rate limiting, request tracing, client routing",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "tsx --env-file-if-exists=../../.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/http-proxy": "^11.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@vela/service-kit": "workspace:*",
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
