# Copy to .env.local. All values are public (inlined into the client bundle).
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STELLAR_NETWORK=testnet
# Defaults target Stellar testnet when unset:
# NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# NEXT_PUBLIC_WALLET_WASM_HASH=<canonical smart-wallet wasm hash; default pinned in lib/config.ts>
